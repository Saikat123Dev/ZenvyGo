# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_BASE_URL=http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000,exp://127.0.0.1:8081

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vehicle_contact
DB_USER=root
DB_PASSWORD=mysql_password
DB_CONNECTION_LIMIT=10

# Redis
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-this-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# PII Vault
PII_VAULT_KEY=0123456789abcdef0123456789abcdef

# OTP Delivery
# mock: logs OTP in server logs and returns debugOtp in development
# email: sends OTP via SMTP email (requires SMTP setup below)
# disabled: stores OTP but skips delivery
OTP_DRIVER=mock

# SMTP Email Configuration
# Required when OTP_DRIVER=email
# For Gmail:
# 1. Enable 2-Factor Authentication
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=ZenvyGo

# Other SMTP providers:
# - SendGrid: smtp.sendgrid.net (port 587)
# - AWS SES: email-smtp.us-east-1.amazonaws.com (port 587)
# - Mailgun: smtp.mailgun.org (port 587)
# - Outlook: smtp-mail.outlook.com (port 587)

# App
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
